PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
JWT_SECRET=change-me
BASE_URL=https://grocerystore-production-eea3.up.railway.app
CORS_ORIGIN=http://localhost:3000,http://localhost:4000,http://localhost:55541,https://grocerystore-production-eea3.up.railway.app

# ABA PayWay KHQR
ABA_MERCHANT_ID=YOUR_MERCHANT_ID
ABA_API_KEY=YOUR_PUBLIC_KEY
# Current QR endpoint from ABA PayWay QR API docs.
ABA_API_URL=https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/generate-qr
ABA_CHECK_TRANSACTION_URL=https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/check-transaction-2
ABA_PAYMENT_OPTION=abapay_khqr
ABA_QR_TEMPLATE=template3_color
ABA_QR_LIFETIME_MINUTES=3

# Optional seed / media settings
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/grocery_store?sslmode=require
SEED_ON_STARTUP=false

# Comma-separated allowed origins for production (localhost allowed in dev)
CORS_ORIGIN=https://flutter-grocery.onrender.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=grocery-products

PAYWAY_MERCHANT_ID=your_payway_merchant_id
PAYWAY_PUBLIC_KEY=your_payway_public_key
PAYWAY_SANDBOX=true
# Use a public HTTPS URL that ABA can reach and whitelist it in PayWay sandbox.
SERVER_PUBLIC_URL=https://your-domain.example.com
PAYWAY_CALLBACK_URL=https://your-domain.example.com/api/payway/pushback
