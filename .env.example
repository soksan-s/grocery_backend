PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
JWT_SECRET=change-me
BASE_URL=https://grocerybackend-production-af0d.up.railway.app
CORS_ORIGIN=http://localhost:3000,http://localhost:4000,http://localhost:55541,https://grocerybackend-production-af0d.up.railway.app
# Google Sign-In server verification audience.
# Use the Google OAuth Web client ID that your Flutter app sends ID tokens for.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com
# Gmail SMTP settings. Use a Google App Password, not your normal Gmail password.
# If Google shows the app password with spaces between groups, you can paste it as-is.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-google-app-password
EMAIL_FROM=Grocery App <your-account@gmail.com>

# ABA PayWay KHQR
ABA_MERCHANT_ID=YOUR_MERCHANT_ID
ABA_API_KEY=YOUR_PUBLIC_KEY
# Current QR endpoint from ABA PayWay QR API docs.
ABA_API_URL=https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/generate-qr
ABA_CHECK_TRANSACTION_URL=https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/check-transaction-2
ABA_PAYMENT_OPTION=abapay_khqr
ABA_QR_TEMPLATE=template3_color
ABA_QR_LIFETIME_MINUTES=3

# Optional seed / media settings
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=flutter-grocery
